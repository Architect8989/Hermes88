# Required — Rhodawk AI Hermes Space secrets
# Set these at: https://huggingface.co/spaces/Architect8999/Hermes/settings

TELEGRAM_BOT_TOKEN=       # @BotFather on Telegram
DO_INFERENCE_API_KEY=     # https://cloud.digitalocean.com/gen-ai — all three agents
GITHUB_PAT=               # GitHub → Settings → Tokens (repo + workflow scopes)

# CRITICAL — Private mode (restrict bot to your chat only)
# Without this, the bot responds to EVERY Telegram user who messages it.
# Find your chat ID: message @userinfobot on Telegram, it replies with your ID.
# Your chat ID: 8215100512
TELEGRAM_CHAT_ID=         # e.g. 8215100512  (comma-separated for multiple owners)

# Optional
HF_TOKEN=                 # HuggingFace write token (enables HF Space push)
BRAVE_API_KEY=            # https://api.search.brave.com/ — enables web search for Hermes

# Camofox stealth browser (v7.1) — VPS deployment only (DO VPS, not HF Spaces)
# Generate with: openssl rand -hex 32
CAMOFOX_ACCESS_KEY=       # Bearer token for camofox REST API at port 9377
