#!/usr/bin/env bash
# jcode — pass-through to the real jcode binary (github.com/1jehuang/jcode)
#
# jcode provides natively: agentic coding loop, file editing, persistent session
# memory (~10 MB/session), swarm coordination server (jcode serve), conflict
# notification when parallel workers touch the same file, and ONNX embeddings.
#
# Do not reimplement any of this. Install the real binary:
#   cargo install jcode
#   OR download from https://github.com/1jehuang/jcode/releases
#
# Usage (passed straight through to the real binary):
#   jcode run --message "..." --workdir /path [--session KEY] [--non-interactive]
#   jcode serve --port 7865
#   jcode --version | --help

set -euo pipefail

for candidate in \
    "$(command -v jcode 2>/dev/null || true)" \
    "$HOME/.cargo/bin/jcode" \
    "$HOME/.local/bin/jcode" \
    "/usr/local/bin/jcode" \
    "/usr/bin/jcode"; do
  if [[ -n "$candidate" && -x "$candidate" ]]; then
    exec "$candidate" "$@"
  fi
done

echo "[jcode] ERROR: jcode binary not found." >&2
echo "  Install: cargo install jcode" >&2
echo "  Or download a release: https://github.com/1jehuang/jcode/releases" >&2
exit 127
